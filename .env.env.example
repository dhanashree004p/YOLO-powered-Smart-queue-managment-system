# Smart Multi-Queue Monitoring System Configuration

# Telegram Configuration
# Get token from @BotFather and chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Authentication Configuration
# Use a long random string for SECRET_KEY
SECRET_KEY=super-secret-key-12345
ADMIN_USERNAME=admin
# Default password is 'admin123'
# To change, generate a new bcrypt hash and update ADMIN_PASSWORD_HASH
ADMIN_PASSWORD_HASH=$2b$12$EixZaYVK1fsbw1ZfbX3OXePaWxn96p36WQoeG6L2GdgG92n.G/UoO
